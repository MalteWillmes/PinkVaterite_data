"Atlantic salmon"  = "paste('Atlantic salmon', '\n', italic('Salmo salar'))",
"Coho salmon"      = "paste('Coho salmon', '\n', italic('Oncorhynchus kisutch'))",
"Chum salmon"      = "paste('Chum salmon', '\n', italic('Oncorhynchus keta'))",
"Steelhead"        = "paste('Steelhead', '\n', italic('Oncorhynchus mykiss'))",
"Chinook salmon"   = "paste('Chinook salmon', '\n', italic('Oncorhynchus tshawytscha'))",
"Lake trout"       = "paste('Lake trout', '\n', italic('Salvelinus namaycush'))"
)
comparison_species <- ggplot() +
geom_jitter(data = filter(vat_study, !is.na(study)),
aes(x = Type, y = vat, color = study, shape = study),
size = 4, alpha = 0.6, width = 0.3, height = 0) +
geom_errorbar(data = summary_data,
aes(x = Type, ymin = mean_vat - sd_vat, ymax = mean_vat + sd_vat),
width = 0.2, linewidth = 1, color = "black") +
geom_point(data = summary_data, aes(x = Type, y = mean_vat),
size = 4, shape = 16) +
scale_shape_manual(values = shape_values) +
facet_grid(
. ~ species,
scales = "free_x",
space = "free_x",
labeller = labeller(species = function(x) latin_names[x], .default = label_parsed)
) +
scale_x_discrete(labels = c(
"Atlantic salmon - farmed" = "Farmed",
"Atlantic salmon - hatchery" = "Hatchery",
"Atlantic salmon - wild" = "Wild",
"Pink salmon - hatchery" = "Hatchery",
"Pink salmon - wild" = "Wild",
"Coho salmon - hatchery" = "Hatchery",
"Coho salmon - wild" = "Wild",
"Chum salmon - hatchery" = "Hatchery",
"Chum salmon - wild" = "Wild",
"Steelhead - hatchery" = "Hatchery",
"Steelhead - wild" = "Wild",
"Chinook salmon - hatchery" = "Hatchery",
"Chinook salmon - wild" = "Wild",
"Lake trout - hatchery" = "Hatchery",
"Lake trout - wild" = "Wild"
)) +
guides(color = guide_legend(na.translate = FALSE),
shape = guide_legend(na.translate = FALSE)) +
labs(color = "Study", shape = "Study",
y = "Prevalence vaterite", x = "") +
theme_classic() +
theme(
panel.border = element_rect(colour = "black", fill = NA, size = 1),
axis.text.x = element_text(size = 15, angle = 45, hjust = 1),
axis.text.y = element_text(size = 15),
axis.title.y = element_text(size = 20),
axis.title.x = element_text(size = 15),
legend.position = "right",
legend.title = element_text(size = 15),
legend.text = element_text(size = 12),
strip.text = element_text(size = 13),
strip.background = element_rect(size = 1)
)
